[Desktop Entry]
Name=Ooze Pak
GenericName=Package Manager
Comment=Install and remove Flatpak apps on Ooze
Exec=ooze-pak %U
Icon=system-software-install
Terminal=false
Type=Application
Categories=System;PackageManager;
StartupNotify=true
StartupWMClass=org.ooze.Pak
MimeType=application/vnd.flatpak;application/vnd.flatpak.ref;application/vnd.flatpak.repo;
SingleMainWindow=true
