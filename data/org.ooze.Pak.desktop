[Desktop Entry]
Name=Software
GenericName=Package Manager
Comment=Ooze Pak — install and remove Flatpak apps
Exec=ooze-pak %U
Icon=system-software-install
Terminal=false
Type=Application
Categories=System;PackageManager;
StartupNotify=true
StartupWMClass=org.ooze.Pak
MimeType=application/vnd.flatpak;application/vnd.flatpak.ref;application/vnd.flatpak.repo;
X-GNOME-SingleWindow=true
