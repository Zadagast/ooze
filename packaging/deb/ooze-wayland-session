#!/usr/bin/env bash
# Primary Wayland session launcher for GDM / wayland-sessions.
# Runs ooze as the session compositor (not nested --devkit).
set -euo pipefail

# Resolve shared env helper (installed or from source tree).
_OOZE_ENV="${OOZE_SESSION_ENV:-}"
if [[ -z "$_OOZE_ENV" ]]; then
  for _cand in \
    /usr/share/ooze/ooze-session-env.sh \
    "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/ooze-session-env.sh"
  do
    if [[ -f "$_cand" ]]; then
      _OOZE_ENV="$_cand"
      break
    fi
  done
fi
# shellcheck source=/dev/null
source "$_OOZE_ENV"

export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
export GSETTINGS_SCHEMA_DIR="${GSETTINGS_SCHEMA_DIR:-/usr/share/glib-2.0/schemas}"
export OOZE_DATA_DIR="${OOZE_DATA_DIR:-/usr/share/ooze}"
export XDG_DATA_DIRS="${OOZE_DATA_DIR}${XDG_DATA_DIRS:+:$XDG_DATA_DIRS}"

ooze_export_foreign_gtk_theme
ooze_export_appmenu_modules

# Native login session: publish desktop id to systemd --user / D-Bus activation,
# start keyring (Recommends), and soft-kick portals. Do not wrap in
# dbus-run-session (that would nest a second bus over the login session).
ooze_push_activation_environment
ooze_start_gnome_keyring
ooze_kick_portals

# Never force nest virtual modes on a real login session.
unset MUTTER_DEBUG_DUMMY_MODE_SPECS

# Mutter private libs (clutter/cogl/mtk) live next to libmutter.
if [[ -d /usr/lib/x86_64-linux-gnu/mutter-18 ]]; then
  export LD_LIBRARY_PATH="/usr/lib/x86_64-linux-gnu/mutter-18${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
elif [[ -d /usr/lib64/mutter-18 ]]; then
  export LD_LIBRARY_PATH="/usr/lib64/mutter-18${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
fi

if command -v gsettings >/dev/null 2>&1; then
  gsettings set org.gnome.mutter edge-tiling true 2>/dev/null || true
  gsettings set org.gnome.desktop.peripherals.mouse drag-threshold 20 2>/dev/null || true
  gsettings set org.gnome.mutter.keybindings toggle-tiled-left "['<Super>Left']" 2>/dev/null || true
  gsettings set org.gnome.mutter.keybindings toggle-tiled-right "['<Super>Right']" 2>/dev/null || true
  # Prefs only — Mutter without GNOME Shell / Ooze lock UI still will not
  # present a lock screen. See README Stability.
  gsettings set org.gnome.desktop.screensaver lock-enabled true 2>/dev/null || true
fi

OOZE_BIN="${OOZE_BIN:-ooze}"
if ! command -v "$OOZE_BIN" >/dev/null 2>&1; then
  echo "ooze-wayland-session: '$OOZE_BIN' not found on PATH" >&2
  exit 1
fi

# Primary compositor: --wayland without --devkit. Xwayland stays on unless
# the user opts out (classic GTK3 global menus need it).
desktop_args=(--wayland)
if [[ "${OOZE_NO_X11:-}" == "1" ]]; then
  desktop_args+=(--no-x11)
fi

ooze_cleanup_portal () {
  local exit_status=$?

  if command -v systemctl >/dev/null 2>&1; then
    systemctl --user --no-block stop xdg-desktop-portal-ooze.service \
      2>/dev/null || true
    systemctl --user --no-block reset-failed xdg-desktop-portal-ooze.service \
      2>/dev/null || true
  fi

  return "$exit_status"
}

trap ooze_cleanup_portal EXIT

# GDM / systemd --user already provide a session bus; do not wrap in
# dbus-run-session (that would nest a second bus over the login session).
if "$OOZE_BIN" "${desktop_args[@]}" "$@"; then
  compositor_status=0
else
  compositor_status=$?
fi

exit "$compositor_status"
