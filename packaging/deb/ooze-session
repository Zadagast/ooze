#!/usr/bin/env bash
# Launch a nested Ooze session from a system install (/usr).
set -euo pipefail

_OOZE_ENV="${OOZE_SESSION_ENV:-}"
if [[ -z "$_OOZE_ENV" ]]; then
  for _cand in \
    /usr/share/ooze/ooze-session-env.sh \
    "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/ooze-session-env.sh"
  do
    if [[ -f "$_cand" ]]; then
      _OOZE_ENV="$_cand"
      break
    fi
  done
fi
# shellcheck source=/dev/null
source "$_OOZE_ENV"

export GSETTINGS_SCHEMA_DIR="${GSETTINGS_SCHEMA_DIR:-/usr/share/glib-2.0/schemas}"
export MUTTER_DEBUG_DUMMY_MODE_SPECS="${OOZE_DISPLAY_MODES:-1600x900:1920x1080:2560x1440:1280x720}"
export OOZE_DATA_DIR="${OOZE_DATA_DIR:-/usr/share/ooze}"
export XDG_DATA_DIRS="${OOZE_DATA_DIR}${XDG_DATA_DIRS:+:$XDG_DATA_DIRS}"

ooze_export_foreign_gtk_theme
ooze_export_appmenu_modules

# Mutter private libs (clutter/cogl/mtk) live next to libmutter.
if [[ -d /usr/lib/x86_64-linux-gnu/mutter-18 ]]; then
  export LD_LIBRARY_PATH="/usr/lib/x86_64-linux-gnu/mutter-18${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
elif [[ -d /usr/lib64/mutter-18 ]]; then
  export LD_LIBRARY_PATH="/usr/lib64/mutter-18${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
fi

if command -v gsettings >/dev/null 2>&1; then
  gsettings set org.gnome.mutter edge-tiling true 2>/dev/null || true
  gsettings set org.gnome.desktop.peripherals.mouse drag-threshold 20 2>/dev/null || true
  gsettings set org.gnome.mutter.keybindings toggle-tiled-left "['<Super>Left']" 2>/dev/null || true
  gsettings set org.gnome.mutter.keybindings toggle-tiled-right "['<Super>Right']" 2>/dev/null || true
fi

OOZE_BIN="${OOZE_BIN:-ooze}"
if ! command -v "$OOZE_BIN" >/dev/null 2>&1; then
  echo "ooze-session: '$OOZE_BIN' not found on PATH" >&2
  exit 1
fi

desktop_args=(--wayland --devkit)
if [[ "${OOZE_NO_X11:-}" == "1" ]]; then
  desktop_args+=(--no-x11)
fi

if command -v dbus-run-session >/dev/null 2>&1; then
  exec dbus-run-session -- "$OOZE_BIN" "${desktop_args[@]}" "$@"
fi

exec "$OOZE_BIN" "${desktop_args[@]}" "$@"
